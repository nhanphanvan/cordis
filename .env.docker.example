CORDIS_ENVIRONMENT=development
CORDIS_HOST=0.0.0.0
CORDIS_PORT=8000
CORDIS_LOG_LEVEL=INFO

CORDIS_DB_URL=postgresql+asyncpg://cordis:cordis@postgres:5432/cordis

CORDIS_SECRET_KEY=cordis-dev-secret-key-change-me
CORDIS_JWT_ALGORITHM=HS256
CORDIS_ACCESS_TOKEN_EXPIRE_MINUTES=60

CORDIS_STORAGE_PROVIDER=minio
CORDIS_STORAGE_BUCKET=cordis-artifacts
CORDIS_STORAGE_PREFIX=
CORDIS_STORAGE_ENDPOINT=minio:9000
CORDIS_STORAGE_ACCESS_KEY=minioadmin
CORDIS_STORAGE_SECRET_KEY=minioadmin
CORDIS_STORAGE_REGION=us-east-1
CORDIS_STORAGE_SECURE=false
CORDIS_STORAGE_PRESIGN_EXPIRY_SECONDS=3600
